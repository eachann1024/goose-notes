{
  "pluginName": "鹅的笔记",
  "description": "本地化的Notion风格笔记",
  "author": "Antigravity",
  "homepage": "https://github.com/your-repo",
  "version": "0.0.1",
  "logo": "logo.png",
  "pluginSetting": {
    "single": true,
    "height": 600
  },
  "features": [
    {
      "code": "gn",
      "explain": "打开鹅的笔记",
      "cmds": [
        "Goose Note",
        "鹅的笔记",
        "笔记",
        "gn"
      ]
    },
    {
      "code": "new_page",
      "explain": "新建笔记",
      "cmds": [
        {
          "type": "over",
          "label": "新建笔记"
        }
      ]
    },
    {
      "code": "open_folder",
      "explain": "打开 Markdown 文件夹",
      "cmds": [
        {
          "type": "files",
          "fileType": "directory",
          "label": "用鹅的笔记打开",
          "maxLength": 1
        }
      ]
    },
    {
      "code": "quicknote_save",
      "explain": "接收速记入库",
      "mainHide": true,
      "cmds": ["速记入库"]
    }
  ],
  "tools": {
    "list_notebooks": {
      "description": "列出鹅的笔记中可访问的记事本，包括应用内记事本与已挂载的本地文件夹记事本。",
      "inputSchema": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "include_local_paths": {
            "type": "boolean",
            "description": "是否返回本地记事本的绝对路径，默认 false。"
          }
        }
      },
      "outputSchema": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "items": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "id": {
                  "type": "string"
                },
                "name": {
                  "type": "string"
                },
                "source": {
                  "type": "string",
                  "enum": [
                    "default",
                    "local-folder"
                  ]
                },
                "availability": {
                  "type": "string",
                  "enum": [
                    "ready",
                    "path_missing",
                    "unreadable"
                  ]
                },
                "localPath": {
                  "type": "string"
                }
              },
              "required": [
                "id",
                "name",
                "source",
                "availability"
              ]
            }
          }
        },
        "required": [
          "items"
        ]
      }
    },
    "list_notes": {
      "description": "分页列出鹅的笔记中的笔记内容，支持按记事本、来源、排序和回收站状态过滤。",
      "inputSchema": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "notebook_ids": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "仅返回指定记事本 ID 下的笔记。"
          },
          "source_types": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": [
                "app-page",
                "local-file"
              ]
            },
            "description": "仅返回指定来源类型的笔记。"
          },
          "limit": {
            "type": "integer",
            "minimum": 1,
            "maximum": 500,
            "description": "单次返回的最大数量，默认 100。"
          },
          "offset": {
            "type": "integer",
            "minimum": 0,
            "description": "分页偏移量，默认 0。"
          },
          "include_trashed": {
            "type": "boolean",
            "description": "是否包含回收站中的应用内笔记，默认 false。"
          },
          "include_folders": {
            "type": "boolean",
            "description": "是否包含本地目录节点，默认 false。"
          },
          "sort_by": {
            "type": "string",
            "enum": [
              "updated_at_desc",
              "updated_at_asc",
              "title_asc"
            ],
            "description": "排序方式，默认 updated_at_desc。"
          }
        }
      },
      "outputSchema": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "total": {
            "type": "integer"
          },
          "items": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "id": {
                  "type": "string"
                },
                "title": {
                  "type": "string"
                },
                "notebookId": {
                  "type": "string"
                },
                "notebookName": {
                  "type": "string"
                },
                "sourceType": {
                  "type": "string",
                  "enum": [
                    "app-page",
                    "local-file"
                  ]
                },
                "parentId": {
                  "type": "string"
                },
                "createdAt": {
                  "type": "number"
                },
                "updatedAt": {
                  "type": "number"
                },
                "isFolder": {
                  "type": "boolean"
                },
                "localFilePath": {
                  "type": "string"
                },
                "snippet": {
                  "type": "string"
                }
              },
              "required": [
                "id",
                "title",
                "notebookId",
                "notebookName",
                "sourceType",
                "createdAt",
                "updatedAt",
                "isFolder",
                "snippet"
              ]
            }
          }
        },
        "required": [
          "total",
          "items"
        ]
      }
    },
    "search_notes": {
      "description": "按关键词搜索鹅的笔记标题和正文，默认不包含文件夹节点。",
      "inputSchema": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "query": {
            "type": "string",
            "description": "要搜索的关键词，不能为空。"
          },
          "notebook_ids": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "source_types": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": [
                "app-page",
                "local-file"
              ]
            }
          },
          "limit": {
            "type": "integer",
            "minimum": 1,
            "maximum": 500,
            "description": "单次返回的最大数量，默认 50。"
          },
          "include_trashed": {
            "type": "boolean",
            "description": "是否包含回收站中的应用内笔记，默认 false。"
          }
        },
        "required": [
          "query"
        ]
      },
      "outputSchema": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "total": {
            "type": "integer"
          },
          "items": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "id": {
                  "type": "string"
                },
                "title": {
                  "type": "string"
                },
                "notebookId": {
                  "type": "string"
                },
                "notebookName": {
                  "type": "string"
                },
                "sourceType": {
                  "type": "string",
                  "enum": [
                    "app-page",
                    "local-file"
                  ]
                },
                "parentId": {
                  "type": "string"
                },
                "createdAt": {
                  "type": "number"
                },
                "updatedAt": {
                  "type": "number"
                },
                "isFolder": {
                  "type": "boolean"
                },
                "localFilePath": {
                  "type": "string"
                },
                "snippet": {
                  "type": "string"
                },
                "score": {
                  "type": "number"
                },
                "matchedFields": {
                  "type": "array",
                  "items": {
                    "type": "string",
                    "enum": [
                      "title",
                      "content"
                    ]
                  }
                }
              },
              "required": [
                "id",
                "title",
                "notebookId",
                "notebookName",
                "sourceType",
                "createdAt",
                "updatedAt",
                "isFolder",
                "snippet",
                "score",
                "matchedFields"
              ]
            }
          }
        },
        "required": [
          "total",
          "items"
        ]
      }
    },
    "get_note": {
      "description": "按笔记 ID 读取单条笔记详情，返回纯文本正文和原始内容结构。",
      "inputSchema": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "note_id": {
            "type": "string",
            "description": "笔记 ID。"
          }
        },
        "required": [
          "note_id"
        ]
      },
      "outputSchema": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "notebookId": {
            "type": "string"
          },
          "notebookName": {
            "type": "string"
          },
          "sourceType": {
            "type": "string",
            "enum": [
              "app-page",
              "local-file"
            ]
          },
          "parentId": {
            "type": "string"
          },
          "createdAt": {
            "type": "number"
          },
          "updatedAt": {
            "type": "number"
          },
          "trashedAt": {
            "type": "number"
          },
          "localFilePath": {
            "type": "string"
          },
          "contentText": {
            "type": "string"
          },
          "rawContentFormat": {
            "type": "string",
            "enum": [
              "blocknote_json",
              "markdown"
            ]
          },
          "rawContent": {}
        },
        "required": [
          "id",
          "title",
          "notebookId",
          "notebookName",
          "sourceType",
          "createdAt",
          "updatedAt",
          "contentText",
          "rawContentFormat",
          "rawContent"
        ]
      }
    }
  },
  "main": "dist/index.html",
  "preload": "preload/preload.cjs"
}
